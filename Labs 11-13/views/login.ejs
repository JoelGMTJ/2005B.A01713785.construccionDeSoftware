<%- include('includes/__header') %>

<form action="/users/login" method="POST">
    <div class="field">
        <label for="username" class="label">Username</label>
        <div class="control">
            <input id="username" name="username" class="input" type="text" required>
        </div>
    </div>

    <div class="field">
        <label for="password" class="label">Password</label>
        <div class="control">
            <input id="password" name="password" class="input" type="password" requires>
        </div>
    </div>

    <input class="button is-primary" type="submit" value="Log In">
</form>

<%- include('includes/__footer') %>