<form action="/users/login" method="POST">
    <div class="content px-6 mx-6   ">

        <div class="field">
            <label for="username" class="label">Username</label>
            <div class="control">
                <input id="username" name="username" class="input" type="text" required>
        </div>
    </div>

    <div class="field">
        <label for="password" class="label">Password</label>
        <div class="control">
            <input id="password" name="password" class="input" type="password" required>
        </div>
    </div>

    <input class="button is-primary" type="submit" value="Entrar">
</div>
</form>