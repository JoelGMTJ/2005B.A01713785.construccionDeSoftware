<form action="/users/signup" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" >
    <div class="content px-6 mx-6   ">

    <div class="field">
        <label for="username" class="label">Username</label>
        <div class="control">
                <input id="username" name="username" class="input" type="text" required>
        </div>
    </div>

    <div class="field">
        <label for="name" class="label">Name</label>
        <div class="control">
                <input id="name" name="name" class="input" type="text" required>
        </div>
    </div>

    <div class="field">
        <label for="password" class="label">Enter your password</label>
        <div class="control">
            <input id="password" name="password" class="input" type="password" required>
        </div>
    </div>

    <div class="field">
        <label for="password_confirm" class="label">Confirm your password</label>
        <div class="control">
            <input id="password_confirm" name="password_confirm" class="input" type="password" required>
        </div>
    </div>

    <input class="button is-primary" type="submit" value="Crear usuario">
</div>
</form>